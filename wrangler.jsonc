{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aoe2museum",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-19",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
